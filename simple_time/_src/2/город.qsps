QSP-Game город


# город
! BASE
*p 'В городе шумно и весело!'
ACT 'Идти к дому':
	! тратим время.
	время = время + 90
	! обновляем календарь
	дни = время / (24*60)
	часы = (время mod (24*60)) / 60
	минуты = время mod 60
	! очищаем окно дополнительного описания
	CLR
	! выводим время на экран:
	PL 'Время: <<дни>> день, <<часы>>:<<минуты>>.'
	! идём
	goto 'улица'
END
! END BASE
-- город ---------------------------------
