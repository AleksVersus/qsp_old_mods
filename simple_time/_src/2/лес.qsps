QSP-Game лес


# лес
! BASE
*p 'В лесу хорошо и тихо...'
ACT 'Идти к дому':
	! тратим время.
	время = время + 20
	! обновляем календарь
	дни = время / (24*60)
	часы = (время mod (24*60)) / 60
	минуты = время mod 60
	! очищаем окно дополнительного описания
	CLR
	! выводим время на экран:
	PL 'Время: <<дни>> день, <<часы>>:<<минуты>>.'
	! идём
	goto 'улица'
END
! END BASE
-- лес ---------------------------------
