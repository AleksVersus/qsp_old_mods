QSP-Game зеркало


# комната_зеркало
! BASE
*p 'В зеркале отражается незаурядная личность весьма приятной наружности.'
ACT 'Отойти от зеркала':
	! тратим время. Мы стояли у зеркала 5 минут
	время = время + 5
	! обновляем информацию на экране
	@@календарь
	! идём на локацию 'комната'
	goto 'комната'
END
! END BASE
-- комната_зеркало ---------------------------------
