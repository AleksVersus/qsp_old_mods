QSP-Game зеркало


# комната_зеркало
! BASE
*p 'В зеркале отражается незаурядная личность весьма приятной наружности.'
ACT 'Отойти от зеркала':
	! тратим время. Мы стояли у зеркала 5 минут
	время = время + 5
	! обновляем календарь
	дни = время / (24*60)
	часы = (время mod (24*60)) / 60
	минуты = время mod 60
	! очищаем окно дополнительного описания
	CLR
	! выводим время на экран:
	PL 'Время: <<дни>> день, <<часы>>:<<минуты>>.'
	! идём на локацию 'комната'
	goto 'комната'
END
! END BASE
