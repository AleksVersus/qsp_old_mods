QSP-Game получение позиции предмета в инвентаре

!@ $0 - название предмета
# ia_obj_getpos
if no obj($args[0]): result = 0 & exit
loop local i = 0 while i < countobj step i += 1:
	!@ pl ['ia_obj_getpos', $getobj(i+1)]
	if $getobj(i+1) = $args[0]: result = i+1 & exit
end
--- ia_obj_getpos ---------------------------------
