QSP-Game Устанавливает или возвращает количество предмета

!@ $0 - название предмета
!@ #1 - количество (если не указано, значит получаем значение)
!@ #r - количество предмета
# ia_obj_count
local $name_ = $args[0]
if no $name_: exit
!@ возвращаем количество
if arrsize('args') = 1: result = IA_COUNT[$name_] & exit

!@ pl ['ia_obj_count', $name_, 'get']
IA_COUNT[$name_] = args[1]
modobj $name_, @ia_obj_get_title($name_)
-- ia_obj_count ---------------------------------