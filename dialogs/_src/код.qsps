! BASE
ACT 'Вернуться в бар':
	USEHTML = 1
	gt 'бар'
END
ACT 'Посмотреть код локации "бар"':
	gt 'код_бар'
END
ACT 'Посмотреть код локации "диалог" (бармен, пьяница)':
	gt 'код_диалог'
END
ACT 'Посмотреть код локации "Диалог_А" (Арагорн)':
	gt 'код_диалог_а'
END
! END BASE
