QSP-Game debugger_save

# debugger_save
! args[0] - autosave

if $debugger_args[0] <> '' and args[0] <> 1:
	!if instr($debugger_args[0],'$') = 1:
		copyarr $debugger_args[0],'$debugger_code'
	!else
	!	copyarr '$<<$debugger_args[0]>>','$debugger_code'
	!end
else
	copyarr '$debugger_autosave','$debugger_code'
end
-- debugger_save ---------------------------------

