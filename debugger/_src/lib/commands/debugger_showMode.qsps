QSP-Game debugger_showMode

# debugger_showMode
if $debugger_args[0] <> '':
	if arrpos('$debugger_mods',$debugger_args[0])>=0:
		$debugger_showMode = $debugger_args[0]
	else
		msg 'Поддерживаемые режимы - ' + func("debugger_implode",", ","$debugger_mods")
	end
else
	msg 'Для изменения режима автопоказа необходимо ввести название режима'
end
-- debugger_showMode ---------------------------------

